{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "suttacentral-ssr",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat_v2", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
}
